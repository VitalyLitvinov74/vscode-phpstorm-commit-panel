{
  "name": "phpstorm-git-panel",
  "displayName": "PhpStorm Commit Panel for VS Code",
  "description": "PhpStorm-style Git commit panel for VS Code with inline diff preview, partial staging, view options, amend, push, and configurable AI messages.",
  "version": "0.4.2",
  "publisher": "vetal",
  "homepage": "https://github.com/VitalyLitvinov74/vscode-phpstorm-commit-panel#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/VitalyLitvinov74/vscode-phpstorm-commit-panel.git"
  },
  "bugs": {
    "url": "https://github.com/VitalyLitvinov74/vscode-phpstorm-commit-panel/issues"
  },
  "engines": {
    "vscode": "^1.129.0"
  },
  "extensionKind": [
    "workspace"
  ],
  "categories": [
    "Other"
  ],
  "keywords": [
    "vscode",
    "visual-studio-code",
    "phpstorm",
    "jetbrains",
    "git",
    "commit",
    "commit-panel",
    "source-control",
    "staging",
    "checkboxes",
    "ai-commit-message",
    "copilot",
    "codex-cli"
  ],
  "activationEvents": [
    "onView:phpstormGitPanel.changes",
    "onCommand:phpstormGitPanel.refresh",
    "onCommand:phpstormGitPanel.stageAll",
    "onCommand:phpstormGitPanel.unstageAll",
    "onCommand:phpstormGitPanel.generateCommitMessage",
    "onCommand:phpstormGitPanel.commit",
    "onCommand:phpstormGitPanel.commitAndPush",
    "onCommand:phpstormGitPanel.openSettings"
  ],
  "main": "./extension.js",
  "scripts": {
    "test": "node test/diff.test.js && node test/git.test.js && node test/stagingBatch.test.js && node test/codexCli.test.js && node test/settingsPanel.test.js && node test/webview.test.js && node test/extension.test.js"
  },
  "contributes": {
    "commands": [
      {
        "command": "phpstormGitPanel.refresh",
        "title": "Refresh PhpStorm Commit Panel",
        "category": "PhpStorm Commit Panel",
        "icon": "$(refresh)"
      },
      {
        "command": "phpstormGitPanel.stageAll",
        "title": "Check All Changes",
        "category": "PhpStorm Commit Panel",
        "icon": "$(check-all)"
      },
      {
        "command": "phpstormGitPanel.unstageAll",
        "title": "Uncheck All Changes",
        "category": "PhpStorm Commit Panel",
        "icon": "$(clear-all)"
      },
      {
        "command": "phpstormGitPanel.generateCommitMessage",
        "title": "Generate Commit Message",
        "category": "PhpStorm Commit Panel",
        "icon": "$(sparkle)"
      },
      {
        "command": "phpstormGitPanel.commit",
        "title": "Commit Checked Changes",
        "category": "PhpStorm Commit Panel",
        "icon": "$(git-commit)"
      },
      {
        "command": "phpstormGitPanel.commitAndPush",
        "title": "Commit and Push Checked Changes",
        "category": "PhpStorm Commit Panel",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "phpstormGitPanel.openSettings",
        "title": "Open PhpStorm Commit Panel Settings",
        "category": "PhpStorm Commit Panel",
        "icon": "$(gear)"
      }
    ],
    "configuration": {
      "title": "PhpStorm Commit Panel",
      "properties": {
        "phpstormGitPanel.autoRefreshIntervalMs": {
          "type": "number",
          "default": 5000,
          "minimum": 1000,
          "description": "How often the PhpStorm Commit Panel refreshes while visible."
        },
        "phpstormGitPanel.commitMessageGenerator": {
          "type": "string",
          "enum": [
            "vscodeLanguageModel",
            "codexCli"
          ],
          "enumItemLabels": [
            "VS Code Language Model (Standard)",
            "Codex CLI"
          ],
          "enumDescriptions": [
            "Use the existing VS Code Language Model API provider, such as GitHub Copilot Chat.",
            "Run the locally installed Codex CLI with its existing authentication."
          ],
          "default": "vscodeLanguageModel",
          "scope": "window",
          "markdownDescription": "Selects the source used to generate Git commit messages. Use the panel gear button or run **PhpStorm Commit Panel: Open PhpStorm Commit Panel Settings** to configure Codex CLI after selecting it."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "phpstormGitPanel.refresh",
          "when": "view == phpstormGitPanel.changes",
          "group": "navigation@1"
        },
        {
          "command": "phpstormGitPanel.stageAll",
          "when": "view == phpstormGitPanel.changes",
          "group": "navigation@2"
        },
        {
          "command": "phpstormGitPanel.unstageAll",
          "when": "view == phpstormGitPanel.changes",
          "group": "navigation@3"
        },
        {
          "command": "phpstormGitPanel.generateCommitMessage",
          "when": "view == phpstormGitPanel.changes",
          "group": "navigation@4"
        },
        {
          "command": "phpstormGitPanel.commit",
          "when": "view == phpstormGitPanel.changes",
          "group": "navigation@5"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "phpstormGitPanel",
          "title": "PhpStorm Git",
          "icon": "./resources/phpstorm-git.svg"
        }
      ]
    },
    "views": {
      "phpstormGitPanel": [
        {
          "id": "phpstormGitPanel.changes",
          "name": "PhpStorm Commit",
          "type": "webview"
        }
      ]
    }
  }
}
